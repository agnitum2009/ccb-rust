version = 2
entry_window = "main"

[windows]
main = "codex1:codex;codex2:codex"

[agents.codex1]
target = "."
runtime_mode = "pane-backed"
restore = "auto"
permission = "manual"
queue_policy = "serial-per-agent"
startup_args = ["-c", "model_reasoning_effort=\"low\""]

[agents.codex2]
target = "."
runtime_mode = "pane-backed"
restore = "auto"
permission = "manual"
queue_policy = "serial-per-agent"
startup_args = ["-c", "model_reasoning_effort=\"low\""]

