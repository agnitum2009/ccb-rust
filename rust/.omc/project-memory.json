  "build": {
    "buildCommand": "cd /home/agnitum/ccb/rust\n# Fix the 4 missing test module references that cause fmt errors\n# These are test module declarations in lib.rs that reference non-existent test files\nfor crate_dir in \\\n    \"ccb-mailbox:re_export_tests/claiming\" \\\n    \"ccb-provider-sessions:tests/discovery\" \\\n    \"ccb-providers:tests/active\" \\\n    \"ccb-storage-classification:tests/models\"; do\n    \n    crate=\"${crate_dir%%:*}\"\n    testpath=\"${crate_dir##*:}\"\n    librs=\"crates/$crate/src/lib.rs\"\n    \n    # The issue is fmt tries to resolve mod declarations that point to non-existent files\n    # Find the line declaring this module and check if the file exists\n    modname=$(basename \"$testpath\")\n    testfile=\"crates/$crate/src/$testpath.rs\"\n    \n    if [ ! -f \"$testfile\" ] && grep -q \"mod $modname\" \"$librs\" 2>/dev/null; then\n        # Create the missing test file as an empty test module\n        mkdir -p \"$(dirname \"$testfile\")\"\n        echo \"//! Test module stub.\" > \"$testfile\"\n        echo \"created $testfile\"\n    fi\ndone\n\necho \"=== fix fmt ===\"\ncargo fmt 2>&1 | head -3\necho \"=== build ===\"\ncargo build --workspace 2>&1 | tail -2\necho \"=== tests ===\"\ncargo test --workspace -- --test-threads=1 2>&1 | grep -E \"^test result:|FAILED\" | head -5",
