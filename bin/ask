#!/usr/bin/env python3
from __future__ import annotations

import os
import sys
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
ROOT_DIR = SCRIPT_DIR.parent


def _find_rust_binary(name: str) -> Path | None:
    """Prefer the Rust debug binary in source checkouts, then release."""
    candidates = [
        ROOT_DIR / "rust" / "target" / "debug" / name,
        ROOT_DIR / "rust" / "target" / "release" / name,
    ]
    for candidate in candidates:
        if candidate.exists() and os.access(candidate, os.X_OK):
            return candidate
    return None


def main() -> int:
    rust_binary = _find_rust_binary("ask")
    if rust_binary:
        os.execv(str(rust_binary), [str(rust_binary), *sys.argv[1:]])

    # Fallback to Python implementation.
    LIB_DIR = ROOT_DIR / "lib"
    if str(LIB_DIR) not in sys.path:
        sys.path.insert(0, str(LIB_DIR))
    from ask_cli import main as ask_main
    return ask_main()


if __name__ == "__main__":
    raise SystemExit(main())
